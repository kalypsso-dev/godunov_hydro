#
# NOTE:
# - this file is a template, you need to substitute NBRICK_X to use it.
# - this substitution is done when submitting a job (see submit_job.sh)
#

[run]
dimension=2
tEnd=0.2
nStepmax=500000

# noutput equals -1 means we dump data at every time steps
nOutput=0

[amr]
level_min=4
level_max=9

use_block_data=yes
bx=16
by=16

# init step may contain calls to globalRefine
# if the following option is true, we interleave
# calls to load balancing in between globalRefine
# if the following option is false, a single load
# balancing operation is done at the end of
# globalRefine steps
enable_load_balance_during_init=false

# refine criterion (used during regular dynamics)
# example parameter for using LOHNER_UNSPLIT criterion
refine_criterion=LOHNER_UNSPLIT
epsilon_refine=0.16
epsilon_coarsen=0.02
epsilon_lohner=0.02

connectivity=brick

# control MPI load balancing (number of time steps between two
# consecutive load balancing)
load_balancing_frequency=30

# control AMR cycle frequency (number of time steps between two
# consecutive AMR cycles)
cycle_frequency=20

#
# when using two AMR refinement criterion (one for init conditions,
# one of the rest of the simulation run), we may want to disable the first amr cycle
# to smooth the transition between the two AMR criterion.
#
disable_first_amr_cycle=yes

#
# prolongation operator used when extrapolating from coarse to fine cell
#
cell_centered_prolongation_type=SIMPLE_COPY
#cell_centered_prolongation_type=EXTRAPOLATE_LINEAR_MINMOD
#cell_centered_prolongation_type=CONSERVATIVE_INTERPOLATION_ORDER_2
#cell_centered_prolongation_type=CONSERVATIVE_INTERPOLATION_ORDER_4

#
# number of octants per computing group (only useful when using implementation 1 or 2)
# larger values improve performance but increase memory footprint
#nbOctsPerGroup=16384

[p4est_connectivity]
nbrick_x=${NBRICK_X}
nbrick_y=${NBRICK_Y}

periodic_x=1
periodic_y=1

[mesh]
xmin=0.0
ymin=0.0

scaling_factor=1.0

boundary_type_xmin=WALL
boundary_type_xmax=WALL

boundary_type_ymin=WALL
boundary_type_ymax=WALL

[hydro]
cfl=0.8
niter_riemann=10
slope_type=2
problem=blast
riemann=HLLC
implementation_version=0
replicated_init_cond=yes

[blast]
radius=0.15
center_x=0.5
center_y=0.5

[material0]
gamma=1.666
pinf=0.0

[region0]
name=inside
rho=1.0
p=10.0

[region1]
name=outside
rho=1.2
p=0.1

[output]
outputDir=./
outputPrefix=test_blast_2D_block_replicated
outputVtkAscii=false
write_variables=rho,rho_vx,rho_vy,e_tot
write_mesh_info=yes
write_iOct=no
hdf5_enabled=yes
enable_writing_leaf_data=no
write_conformal_status=no
