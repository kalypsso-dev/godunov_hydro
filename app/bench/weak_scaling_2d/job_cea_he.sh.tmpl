#!/bin/bash
#MSUB -r kalypsso_gpu                   # Request name
#MSUB -n ${NGPU}                        # Total number of tasks to use
#MSUB -c 72                             # Assuming compute nodes have 4 GH200, 72 ARM cores each
#MSUB -T 1800                           # Elapsed time limit in seconds
#MSUB -o kalypsso_2d_gpu_${NGPU}_%I.o   # Standard output. %I is the job id
#MSUB -e kalypsso_2d_gpu_${NGPU}_%I.o   # Error output. %I is the job id
#MSUB -q he                             # Choosing partition of GPU nodes
#MSUB -m work,scratch

${PROJ_ID_ENABLE}#MSUB -A ${PROJECT_ID}               # Project ID
set -x
cd ${BRIDGE_MSUB_PWD}

module load gcc/13.3.0 cuda/12.4 feature/openmpi/net/bxi/ubcl_shmem_disable mpi/openmpi/4.1.8.3 flavor/hdf5/parallel hdf5/1.14.3

echo "##############################################################"
echo "Print submit job:"
cat $0
echo "##############################################################"

cd ${BRIDGE_MSUB_PWD}

INI_FILE=${INI_FILENAME}
cat $INI_FILE

# set the number of OpenMP threads per MPI task
export OMP_NUM_THREADS=72
export OMP_PROC_BIND=spread
export OMP_PLACES=threads

# launch computation with 1 GPU per MPI task
ccc_mprun @CMAKE_CURRENT_BINARY_DIR@/solver_godunov_hydro --ini $INI_FILE --kokkos-map-device-id-by=mpi_rank
