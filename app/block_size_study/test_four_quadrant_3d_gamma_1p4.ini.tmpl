[run]
dimension=3
tEnd=0.8
nStepmax=200000

# noutput equals -1 means we dump data at every time steps
nOutput=1

[amr]
level_min=2
level_max=4

use_block_data=yes
bx=4
by=4
bz=4

# amr refine criterion use at init condition
# possible value: ALWAYS_REFINE, GEOMETRIC, SAME_AS_REGULAR_DYNAMICS
refine_criterion_at_init=GEOMETRIC

# init step may contain calls to globalRefine
# if the following option is true, we interleave
# calls to load balancing in between globalRefine
# if the following option is false, a single load
# balancing operation is done at the end of
# globalRefine steps
enable_load_balance_during_init=false

# refine criterion (used during regular dynamics)
# example parameter for using LOHNER_UNSPLIT criterion
refine_criterion=LOHNER_UNSPLIT
epsilon_refine=0.64
epsilon_coarsen=0.08
epsilon_lohner=0.02

# example parameter for using LOHNER_UNSPLIT criterion
#refine_criterion=SIMPLE_GRADIENT
#epsilon_refine=0.1
#epsilon_coarsen=0.01

# p4est connectivity type
connectivity=brick

# control MPI load balancing (number of time steps between two
# consecutive load balancing)
load_balancing_frequency=20

# control AMR cycle frequency (number of time steps between two
# consecutive AMR cycles)
cycle_frequency=10

[p4est_connectivity]
nbrick_x=1
nbrick_y=1
nbrick_z=1

periodic_x=0
periodic_y=0
periodic_z=0

[mesh]
xmin=0.0
ymin=0.0
zmin=0.0

scaling_factor=1.0

boundary_type_xmin=ZERO_GRADIENT
boundary_type_xmax=ZERO_GRADIENT

boundary_type_ymin=ZERO_GRADIENT
boundary_type_ymax=ZERO_GRADIENT

boundary_type_zmin=ZERO_GRADIENT
boundary_type_zmax=ZERO_GRADIENT

[hydro]
cfl=0.8
niter_riemann=10
slope_type=2
problem=four_quadrant
riemann=HLLC
implementation_version=0

[four_quadrant]
config_number=2
x=0.8
y=0.8
z=0.8

[material0]
gamma=1.4

[output]
outputDir=./
outputPrefix=test_four_quadrant_3d_gamma_1p4
outputVtkAscii=false
write_variables=rho
write_mesh_info=no
write_mesh_level=yes
write_iOct=no
hdf5_enabled=yes
enable_writing_leaf_data=no
write_conformal_status=no
